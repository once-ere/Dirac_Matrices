Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   SuperscriptBox["\[CapitalSigma]", "\[Alpha]\[Beta]"], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SuperscriptBox["\[CapitalSigma]", "\[Alpha]\[Beta]"], "[", "f_", "]"}], 
  RowBox[{"(*", 
   RowBox[{"/;", 
    RowBox[{
     RowBox[{"Head", "[", "f", "]"}], "===", "Symbol"}]}], "*)"}], ":=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Su", ",", "d"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Su", "=", 
        RowBox[{"f", "*", 
         RowBox[{
          RowBox[{
           StyleBox[
            RowBox[{
             StyleBox["S44",
              FontSize->14], "\[Alpha]\[Beta]"}]], "[", 
           RowBox[{"[", 
            RowBox[{"h", ",", "k"}], "]"}], "]"}], ".", "U1by4"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"d", "=", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[ImaginaryI]"}], "*", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Su", "[", 
               RowBox[{"[", "j", "]"}], "]"}], ",", 
              RowBox[{"U1by4", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "1", ",", 
             RowBox[{"Length", "[", "U1by4", "]"}]}], "}"}]}], "]"}], "]"}]}],
        ";", "\[IndentingNewLine]", "d"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"h", ",", "1", ",", "4"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", "1", ",", "4"}], "}"}]}], "]"}]}]}], "Input",
