Cell[CellGroupData[{

Cell["\<\
Dirac spinor with components  u\.aa, a = 1, 2, 3, 4;  irrep, and  DD\[Xi], ...\
\>", "Section",
 CellChangeTimes->{{3.9749057924765263`*^9, 3.974905803236763*^9}, {
  3.974905928421503*^9, 3.974905969813404*^9}, {3.974970594702177*^9, 
  3.9749706109759483`*^9}, {3.97507913874543*^9, 3.975079161242853*^9}},
 FontSize->14,ExpressionUUID->"fd1670bd-6029-4780-9fad-be60b090a9b2"],

Cell[TextData[{
 "The Wigner D-function ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["D", 
    RowBox[{
     SubscriptBox["m", "1"], ",", 
     SubscriptBox["m", "2"]}], "j"], TraditionalForm]], "InlineMath",
  ExpressionUUID->"f2c72844-b154-444e-bf6c-65bd5a8efe5f"],
 " gives the matrix element of a rotation operator parametrized by Euler \
angles in a ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"2", " ", "j"}], "+", "1"}], TraditionalForm]], "InlineMath",
  ExpressionUUID->"3ebd01f1-67e5-4b7f-ac54-4e7ce51bcecd"],
 "\[Dash]dimensional unitary representation of a rotation group when \
parameters ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]], "InlineMath",ExpressionUUID->
  "bbe4abc7-2033-4fc9-b8c3-f97a57466299"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "d4f51e70-5ee5-47fd-86e1-29abb51ce3ca"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]], "InlineMath",ExpressionUUID->
  "47b47181-9d6a-413a-ba27-ab6790a40286"],
 " are physical, i.e. all integers or half-integers such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"-", "j"}], "\[LessEqual]", 
     SubscriptBox["m", "1"]}], ",", 
    RowBox[{
     SubscriptBox["m", "2"], "\[LessEqual]", "j"}]}], TraditionalForm]], 
  "InlineMath",ExpressionUUID->"aca47648-9a0c-47bb-bc64-c1504223d90d"],
 "."
}], "Notes",
 FontSize->14,
 CellID->101546122,ExpressionUUID->"34f4d6c1-32fa-4646-ad0d-935eb5d6da33"],

Cell[TextData[{
 "For unphysical parameters, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WignerD"]], "paclet:ref/WignerD"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "975f0cba-a3d3-4883-8ffb-dfc108381b42"],
 " is defined by an analytic continuation."
}], "Notes",
 FontSize->14,
 CellID->226333600,ExpressionUUID->"5294e993-cc64-4e4f-aad4-5b117b16f783"],

Cell[TextData[{
 "The Wolfram Language",
 " uses phase conventions where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"j", 
      SubscriptBox["m", "1"], 
      SubscriptBox["m", "2"], "\[Psi]", "\[Theta]", "\[Phi]"},
     "WignerD"], "\[LongEqual]", 
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{"\[ImaginaryI]", " ", 
        SubscriptBox["m", "1"], " ", "\[Psi]"}], "+", 
       RowBox[{"\[ImaginaryI]", " ", 
        SubscriptBox["m", "2"], "\[Phi]"}]}], ")"}], " ", 
     TemplateBox[{"j", 
       SubscriptBox["m", "1"], 
       SubscriptBox["m", "2"], "0", "\[Theta]", "0"},
      "WignerD"]}]}], TraditionalForm]], "InlineMath",ExpressionUUID->
  "624f311f-5a67-4e5c-a45a-ca92abe6c4dc"],
 "."
}], "Notes",
 FontSize->14,
 CellID->287940785,ExpressionUUID->"77ae6a33-f5ad-4147-ba71-f850b9e905c7"],

Cell[BoxData[Cell[TextData[{
  Cell[BoxData[
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["WignerD"]], "paclet:ref/WignerD"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       StyleBox["j", "TI"], ",", 
       SubscriptBox[
        StyleBox["m", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["m", "TI"], 
        StyleBox["2", "TR"]]}], "}"}], ",", 
     StyleBox["\[Psi]", "TR"], ",", 
     StyleBox["\[Theta]", "TR"], ",", 
     StyleBox["\[Phi]", "TR"]}], "]"}]], "InlineFormula",
   FontFamily->"Source Sans Pro",ExpressionUUID->
   "03cad587-dd2c-4c7f-99f9-68e3507b7069"],
  " \[LineSeparator]gives the Wigner D-function ",
  Cell[BoxData[
   FormBox[
    RowBox[{
     SubsuperscriptBox["D", 
      RowBox[{
       SubscriptBox["m", "1"], ",", 
       SubscriptBox["m", "2"]}], "j"], "(", 
     RowBox[{"\[Psi]", ",", "\[Theta]", ",", "\[Phi]"}], ")"}], 
    TraditionalForm]], "InlineMath",ExpressionUUID->
   "092cd916-c979-44e5-b40b-2cdf5b26e847"],
  "."
 }],ExpressionUUID->"b47eaa06-7a50-4acc-a971-20ccf2dec8bc"]], "Text",
 CellChangeTimes->{3.975078475788986*^9},
 FontSize->14,ExpressionUUID->"669d17c8-0a88-498d-83a6-b656751a6e8c"],

