Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", 
   SuperscriptBox["\[CapitalSigma]", "2"], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SuperscriptBox["\[CapitalSigma]", "2"], "[", "f_", "]"}], 
  RowBox[{"(*", 
   RowBox[{"/;", 
    RowBox[{
     RowBox[{"Head", "[", "f", "]"}], "===", "Symbol"}]}], "*)"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"u", ",", "n", ",", "sa", ",", "sb", ",", "d"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"u", "=", "U1by4"}], ";", 
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "u", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"sa", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"u", "[", 
            RowBox[{"[", "a1", "]"}], "]"}], "*", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"u", "[", 
               RowBox[{"[", "b", "]"}], "]"}], 
              RowBox[{"D", "[", 
               RowBox[{"f", ",", 
                RowBox[{"u", "[", 
                 RowBox[{"[", "b", "]"}], "]"}]}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"b", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ",", 
          RowBox[{"u", "[", 
           RowBox[{"[", "a1", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"a1", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"sb", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"u", "[", 
                RowBox[{"[", "b", "]"}], "]"}], 
               RowBox[{"u", "[", 
                RowBox[{"[", "b", "]"}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"b", ",", "1", ",", "n"}], "}"}]}], "]"}], 
            RowBox[{"D", "[", 
             RowBox[{"f", ",", 
              RowBox[{"u", "[", 
               RowBox[{"[", "a1", "]"}], "]"}]}], "]"}]}], ")"}], ",", 
          RowBox[{"u", "[", 
           RowBox[{"[", "a1", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"a1", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"d", "=", 
        RowBox[{"sa", "-", "sb"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"d", "=", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        FractionBox["1", "4"], 
        RowBox[{"(", 
         RowBox[{"sa", "-", "sb"}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "d", "]"}], ";"}]}], "]"}]}]}], "Input",
