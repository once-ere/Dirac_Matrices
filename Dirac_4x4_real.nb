Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"processInput", "[", "input_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"f", ",", "vars"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Head", "[", "input", "]"}], "===", "Function"}], ",", 
        RowBox[{"f", "=", "input"}], ",", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "input", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "vars", "]"}], "===", "1"}], ",", 
           RowBox[{"f", "=", 
            RowBox[{"Function", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"vars", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "}"}], ",", 
              RowBox[{"Evaluate", "[", "input", "]"}]}], "]"}]}], ",", 
           RowBox[{
           "Return", 
            "[", "\"\<Error: Expression must have only one variable.\>\"", 
            "]"}]}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Use", "'"}], 
        RowBox[{"f", "'"}], " ", "here"}], "*)"}], 
      RowBox[{"f", "[", "10", "]"}]}]}], "]"}]}], "\n"}]], "Input",
 CellChangeTimes->{{3.9749820475218487`*^9, 3.9749820573550644`*^9}},
 FontSize->14,
 CellLabel->
  "In[141]:=",ExpressionUUID->"f33f6a38-da97-4451-8b1e-0d8838c3ae15"],

Cell[BoxData[
 GraphicsBox[
  TagBox[RasterBox[CompressedData["
