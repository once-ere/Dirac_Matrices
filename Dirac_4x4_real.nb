           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "1"}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{"k", "+", "mp", "-", "m"}], ")"}]}], "*", 
           RowBox[{"(*", 
            RowBox[{"Trigonometric", " ", "terms"}], "*)"}], 
