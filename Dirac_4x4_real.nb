Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"h", ",", "k"}], "}"}], ",", 
      RowBox[{
       RowBox[{"FullSimplify", "[", 
        FractionBox[
         RowBox[{
          RowBox[{
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", "h", "]"}], "]"}], ".", 
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", "k", "]"}], "]"}]}], "+", 
          RowBox[{
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", "k", "]"}], "]"}], ".", 
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", "h", "]"}], "]"}]}]}], "2"], "]"}], "===", 
       RowBox[{
        RowBox[{
         SubscriptBox["g", "\[Alpha]\[Beta]"], "[", 
         RowBox[{"[", 
          RowBox[{"h", ",", "k"}], "]"}], "]"}], "ID4"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"h", ",", "1", ",", "4"}], "}"}], ",", 
